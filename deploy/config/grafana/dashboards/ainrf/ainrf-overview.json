{
  "annotations": {
    "list": []
  },
  "description": "OpenScience platform overview — HTTP, auth, terminal, sessions",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "HTTP Request Rate",
      "description": "Requests per second by status code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(ainrf_http_requests_total[5m])",
          "legendFormat": "{{method}} {{path}} {{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "title": "HTTP Error Rate",
      "description": "5xx errors as fraction of all requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.01, "color": "yellow" },
              { "value": 0.05, "color": "red" }
            ]
          },
          "max": 1
        }
      },
      "targets": [
        {
          "expr": "sum(rate(ainrf_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(ainrf_http_requests_total[5m]))",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "P95 Latency",
      "description": "95th percentile request duration",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ainrf_http_request_duration_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Request Duration Histogram",
      "description": "Latency distribution over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ainrf_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(ainrf_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ainrf_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "Login Success / Failure",
      "description": "Authentication outcomes over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "failed.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "success.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(ainrf_auth_login_success_total[5m])",
          "legendFormat": "success",
          "refId": "A"
        },
        {
          "expr": "rate(ainrf_auth_login_failed_total[5m])",
          "legendFormat": "failed {{reason}}",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }
      }
    },
    {
      "title": "Terminal Exec Commands",
      "description": "Allowed vs denied terminal commands",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "denied" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(ainrf_terminal_exec_total[5m])",
          "legendFormat": "exec",
          "refId": "A"
        },
        {
          "expr": "rate(ainrf_terminal_exec_denied_total[5m])",
          "legendFormat": "denied",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "Active WebSocket Sessions",
      "description": "Currently open terminal WebSocket connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 50, "color": "yellow" },
              { "value": 100, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "ainrf_terminal_ws_active",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Sensitive File Access",
      "description": "Access attempts to sensitive paths",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50
          },
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      },
      "targets": [
        {
          "expr": "increase(ainrf_files_sensitive_path_access_total[5m])",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "Environment Updates",
      "description": "Environment detection/update operations",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(ainrf_environment_update_total[5m])",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "Code Sessions Created",
      "description": "Total code-server sessions spawned",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "increase(ainrf_code_session_created_total[1h])",
          "legendFormat": "last hour",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Task Execution Rate",
      "description": "Tasks created, completed, and failed over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "failed.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "created.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "completed.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(ainrf_task_created_total[5m])",
          "legendFormat": "created {{researcher_type}}",
          "refId": "A"
        },
        {
          "expr": "rate(ainrf_task_completed_total[5m])",
          "legendFormat": "completed {{status}}",
          "refId": "B"
        },
        {
          "expr": "rate(ainrf_task_failed_total[5m])",
          "legendFormat": "failed {{researcher_type}}",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }
      }
    },
    {
      "title": "SSH Command Latency",
      "description": "SSH remote command execution duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ainrf_ssh_command_duration_seconds_bucket[5m])) by (le, host))",
          "legendFormat": "p50 {{host}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ainrf_ssh_command_duration_seconds_bucket[5m])) by (le, host))",
          "legendFormat": "p95 {{host}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ainrf_ssh_command_duration_seconds_bucket[5m])) by (le, host))",
          "legendFormat": "p99 {{host}}",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "SSH Connection Errors",
      "description": "SSH connection errors by host and error type",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50
          },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "targets": [
        {
          "expr": "increase(ainrf_ssh_connection_error_total[5m])",
          "legendFormat": "{{host}} {{error_type}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "Slow DB Queries",
      "description": "Database queries exceeding 1 second threshold",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 10, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "increase(ainrf_db_slow_query_total[1h])",
          "legendFormat": "{{db}}",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["ainrf"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "OpenScience Overview",
  "uid": "ainrf-overview",
  "version": 1
}
