{
  "env": {
    "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
    "ANTHROPIC_AUTH_TOKEN": "${ANTHROPIC_API_KEY}",
    "ANTHROPIC_BASE_URL": "${ANTHROPIC_BASE_URL}",
    "ANTHROPIC_MODEL": "${ANTHROPIC_MODEL}",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "${ANTHROPIC_MODEL}",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "${ANTHROPIC_MODEL}",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "${ANTHROPIC_MODEL}",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "200000"
  },
  "permissions": {
    "allow": [],
    "deny": [
      "Read(/opt/ainrf/state/**)",
      "Write(/opt/ainrf/state/**)",
      "Edit(/opt/ainrf/state/**)",
      "Read(/opt/ainrf/config/**)",
      "Write(/opt/ainrf/config/**)",
      "Edit(/opt/ainrf/config/**)",
      "Read(/opt/ainrf/aris-repo/**)",
      "Write(/opt/ainrf/aris-repo/**)",
      "Edit(/opt/ainrf/aris-repo/**)",
      "Write(/opt/ainrf/.ainrf_workspaces/**/skills/**)",
      "Edit(/opt/ainrf/.ainrf_workspaces/**/skills/**)",
      "Read(/home/ainrf_tenants/**)",
      "Write(/home/ainrf_tenants/**)",
      "Edit(/home/ainrf_tenants/**)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chown *)",
      "Bash(useradd *)",
      "Bash(userdel *)",
      "Bash(groupadd *)",
      "Bash(passwd *)"
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
