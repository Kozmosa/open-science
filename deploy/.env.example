# ── AINRF Docker Deployment Environment ──────────────────────────
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Generate secrets:
#   JWT secret:  python -c "import secrets; print(secrets.token_urlsafe(48))"
#   API key:     python -c "import secrets; print(secrets.token_urlsafe(32))"
#   API key hash (put this below):
#                python -c "from hashlib import sha256; print(sha256(b'YOUR_API_KEY').hexdigest())"
# ────────────────────────────────────────────────────────────────

AINRF_JWT_SECRET=CHANGE_ME
AINRF_API_KEY_HASHES=CHANGE_ME
