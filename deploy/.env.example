# ── OpenScience Docker Deployment Environment ──────────────────────────
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Generate secrets:
#   JWT secret:  python3 -c "import secrets; print(secrets.token_urlsafe(48))"
#   API key:     python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#   API key hash (put this below):
#                python3 -c "from hashlib import sha256; print(sha256(b'YOUR_API_KEY').hexdigest())"
#
# TLS:
#   Place cert at ./tls/cert.pem and key at ./tls/key.pem
#   For lab: bash deploy/tls/generate-self-signed.sh
# ────────────────────────────────────────────────────────────────

# ── Required ───────────────────────────────────────────────────
AINRF_JWT_SECRET=CHANGE_ME_generate_with_secrets_token_urlsafe_48
AINRF_API_KEY_HASHES=CHANGE_ME_sha256_hex_of_your_api_key

# ── Registration ───────────────────────────────────────────────
AINRF_PUBLIC_REGISTRATION_ENABLED=false

# ── Ports ──────────────────────────────────────────────────────
HTTPS_PORT=443
HTTP_PORT=80
