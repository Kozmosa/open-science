---
const techs = [
  { name: "Python 3.13+", icon: "🐍" },
  { name: "FastAPI", icon: "⚡" },
  { name: "React 19", icon: "⚛️" },
  { name: "Vite", icon: "📦" },
  { name: "TypeScript", icon: "📘" },
  { name: "Docker", icon: "🐳" },
  { name: "Prometheus", icon: "📊" },
  { name: "Grafana", icon: "📈" },
  { name: "SQLite", icon: "🗄️" },
  { name: "uv", icon: "🦀" },
];
---

<section class="os-section os-tech">
  <h2 class="os-section__title">技术栈</h2>
  <div class="os-tech__grid">
    {techs.map((item) => (
      <span class="os-tech__badge">
        <span class="os-tech__icon">{item.icon}</span>
        {item.name}
      </span>
    ))}
  </div>
</section>

<style is:global>
.os-tech {
  max-width: 960px;
}

.os-tech__grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0.6rem;
  justify-content: center;
}

.os-tech__badge {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.4rem 0.9rem;
  border-radius: 999px;
  font-size: 0.82rem;
  font-weight: 500;
  border: 1px solid color-mix(in srgb, var(--sl-color-text) 8%, transparent);
  background: var(--sl-color-bg);
  color: var(--sl-color-text);
}

.os-tech__icon {
  font-size: 0.95rem;
}
</style>
