---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<section class="os-section">
  <h2 class="os-section__title">{title}</h2>
  <div class="os-feature-grid">
    <slot />
  </div>
</section>

<style is:global>
.os-section {
  max-width: 960px;
  margin: 0 auto;
  padding: 3rem 2rem;
}

.os-section__title {
  font-size: 1.5rem;
  font-weight: 700;
  text-align: center;
  margin: 0 0 2rem;
  color: var(--sl-color-text);
}

.os-feature-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1rem;
}
</style>
