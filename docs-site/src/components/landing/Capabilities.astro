---
const capabilities = [
  { name: "项目管理", desc: "ReactFlow Canvas DAG 可视化、任务创建与连线", href: "/scholar-agent/projects/" },
  { name: "终端管理", desc: "Personal/Agent 会话、本地 bash、远程 SSH+tmux", href: "/scholar-agent/terminal/" },
  { name: "工作区", desc: "目录管理、文件浏览器、Monaco 编辑器", href: "/scholar-agent/workspace/" },
  { name: "会话追踪", desc: "Session/Attempt 链、成本与耗时统计", href: "/scholar-agent/sessions/" },
  { name: "时间线", desc: "Gantt 图可视化任务时间分布", href: "/scholar-agent/timeline/" },
  { name: "资源监控", desc: "GPU/CPU/内存实时监控、进程树", href: "/scholar-agent/resources/" },
  { name: "系统设置", desc: "用户偏好、LLM Provider、技能仓库", href: "/scholar-agent/settings/" },
  { name: "安全架构", desc: "三层纵深防御、审计事件、敏感路径检测", href: "/scholar-agent/security/" },
  { name: "可观测性", desc: "审计日志、Prometheus 指标、Grafana 监控栈", href: "/scholar-agent/observability/" },
];
---

<section class="os-section os-caps">
  <h2 class="os-section__title">功能一览</h2>
  <div class="os-caps__grid">
    {capabilities.map((item) => (
      <a href={item.href} class="os-caps__item">
        <span class="os-caps__name">{item.name}</span>
        <span class="os-caps__desc">{item.desc}</span>
      </a>
    ))}
  </div>
</section>

<style is:global>
.os-caps {
  max-width: 960px;
}

.os-caps__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 0.75rem;
}

.os-caps__item {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  padding: 1rem 1.25rem;
  border-radius: 8px;
  border: 1px solid color-mix(in srgb, var(--sl-color-text) 6%, transparent);
  background: var(--sl-color-bg);
  text-decoration: none;
  transition: all 0.2s ease;
}

.os-caps__item:hover {
  border-color: color-mix(in srgb, var(--sl-color-accent) 25%, transparent);
  background: color-mix(in srgb, var(--sl-color-accent) 3%, var(--sl-color-bg));
}

.os-caps__name {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--sl-color-text);
}

.os-caps__desc {
  font-size: 0.8rem;
  line-height: 1.4;
  color: var(--sl-color-text-muted);
}
</style>
