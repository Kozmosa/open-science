<style is:global>
.os-cta {
  max-width: 800px;
  text-align: center;
  padding-top: 2rem;
  padding-bottom: 4rem;
}

.os-cta__title {
  font-size: 1.5rem;
  font-weight: 700;
  margin: 0 0 0.5rem;
  color: var(--sl-color-text);
}

.os-cta__desc {
  font-size: 1rem;
  color: var(--sl-color-text-muted);
  margin: 0 0 1.5rem;
}

.os-cta__actions {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
}
</style>
