<section class="os-section os-cta">
  <div class="os-cta__inner">
    <h2 class="os-cta__title">开始使用 OpenScience</h2>
    <p class="os-cta__desc">
      从一行命令启动，三分钟上手。
    </p>
    <div class="os-cta__actions">
      <a href="/scholar-agent/quickstart/" class="os-hero__btn os-hero__btn--primary">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
